          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ranked AS (\n    SELECT\n        latitude,\n        longitude,\n        risk_score,\n        alert_status,\n        governorate,\n        zone,\n        CASE\n            WHEN alert_status = 'CRITICAL' THEN 100\n            WHEN alert_status = 'WARNING'  THEN 50\n            ELSE 0\n        END AS severity_level,\n        ROW_NUMBER() OVER (\n            PARTITION BY house_id\n            ORDER BY CASE alert_status WHEN 'CRITICAL' THEN 0 ELSE 1 END, risk_score DESC\n        ) AS rn\n    FROM gold.active_alerts\n    WHERE alert_status != 'NORMAL'\n      AND latitude IS NOT NULL\n      AND batch_id = (SELECT MAX(batch_id) FROM gold.active_alerts)\n)\nSELECT latitude, longitude, risk_score, alert_status, governorate, zone, severity_level\nFROM ranked\nWHERE rn = 1",
